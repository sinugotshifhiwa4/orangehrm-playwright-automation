#!/usr/bin/env sh
set -e

echo "Running pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.js')

if [ -z "$STAGED_FILES" ]; then
  echo "No staged JS/TS files to check."
  exit 0
fi

HAS_ERROR=0

echo "Checking for focused tests and console.log..."

for file in $STAGED_FILES; do
  if git show ":$file" | grep -E -q '\.[[:space:]]*only[[:space:]]*\('; then
    echo "Focused test detected: $file"
    git show ":$file" | grep -E -n '\.[[:space:]]*only[[:space:]]*\('
    HAS_ERROR=1
  fi

  if git show ":$file" | grep -q 'console\.log'; then
    echo "console.log detected: $file"
    git show ":$file" | grep -n 'console\.log'
    HAS_ERROR=1
  fi
done

if [ "$HAS_ERROR" -eq 1 ]; then
  echo "Fix the above issues before committing."
  exit 1
fi

echo "Checks passed. Running lint-staged..."
npx lint-staged
echo "All pre-commit checks passed!"